{
  "name": "applymanager",
  "version": "0.8.1-alpha",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "dev:api": "uvicorn server.main:app --reload --host 0.0.0.0 --port 3000",
    "dev:full": "concurrently -k -n FE,API \"npm:dev\" \"npm:dev:api\"",
    "dev:db": "docker compose up -d db",
    "dev:desktop": "concurrently -k -n FE,API,ELECTRON \"npm:dev\" \"npm:dev:api\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:1420 && electron .",
    "build": "tsc && vite build",
    "build:desktop": "npm run build && electron-builder",
    "preview": "vite preview",
    "start": "uvicorn server.main:app --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.13.1",
    "playwright": "1.59.1",
    "powerbi-client": "^2.23.10",
    "powerbi-client-react": "^2.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "pl.applymanager.desktop",
    "productName": "ApplyManager",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    }
  }
}
