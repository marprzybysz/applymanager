{
  "name": "applymanager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "uvicorn server_py.main:app --reload --host 0.0.0.0 --port 3000",
    "dev:full": "concurrently -k -n FE,API \"npm:dev\" \"npm:dev:api\"",
    "dev:db": "docker compose up -d db",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "start": "uvicorn server_py.main:app --host 0.0.0.0 --port 3000"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "cheerio": "^1.0.0",
    "express": "^4.21.1",
    "multer": "^1.4.5-lts.1",
    "playwright": "1.59.1",
    "pg": "^8.13.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.9",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
